<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo Priority Regression Suite" parallel="false">
  <test name="Priority Regression Tests">
    <groups>
      <run>
        <include name="priority"/>
      </run>
    </groups>
    <classes>
      <class name="com.saucedemo.ai.tests.LoginRegressionTest"/>
      <class name="com.saucedemo.ai.tests.ProductCatalogRegressionTest"/>
      <class name="com.saucedemo.ai.tests.CartRegressionTest"/>
      <class name="com.saucedemo.ai.tests.CheckoutRegressionTest"/>
      <class name="com.saucedemo.ai.tests.NavigationSecurityRegressionTest"/>
      <class name="com.saucedemo.ai.tests.UserInterfaceRegressionTest"/>
    </classes>
  </test>
</suite>
